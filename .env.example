# Required environment variables — copy to .env and fill in values

# Database (Supabase PostgreSQL)
DATABASE_URL=""

# Encryption key for API credentials (32 char string)
ENCRYPTION_KEY=""

# Cron job protection secret
CRON_SECRET=""

# Admin basic auth credentials
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# App URL (used for internal API calls in cron jobs)
NEXT_PUBLIC_APP_URL=""

# Namecheap API (configured via Settings UI, but can also be set here)
# NAMECHEAP_USER=""
# NAMECHEAP_KEY=""
# NAMECHEAP_SANDBOX="true"

# DataForSEO backlink API
# DATAFORSEO_EMAIL=""
# DATAFORSEO_PASSWORD=""

# Cloudflare API token (Zone:Edit permission)
# CLOUDFLARE_API_TOKEN=""

# Resend email API key
# RESEND_API_KEY=""

# Majestic TF/CF API key (optional — leave blank to use free tier)
# MAJESTIC_API_KEY=""
